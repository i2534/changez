// OpenCode TUI Plugin: changez — 状态通知 (TUI 插件)
//
// 仅依赖 opencode TUI API，零外部依赖。
// 初始化时检查 changez 服务连通性，通过 toast 通知用户加载结果。
//
// 配对文件：changez.server.ts（核心 Server 插件）
//
// 安装方式：
//   全局：~/.config/opencode/plugins/changez.tui.ts
//   项目级：{project}/.opencode/plugins/changez.tui.ts
//
// 配置（opencode.json）：
//   {
//     "plugin": [
//       ["file://./client/opencode/changez.tui.ts", {
//         "url": "http://127.0.0.1:8760"
//       }]
//     ]
//   }

import * as fs from "node:fs";
import * as http from "node:http";
import * as https from "node:https";
import * as path from "node:path";

type TuiConfig = {
  url: string;
};

type TuiPluginApi = {
  ui: {
    toast: (input: {
      variant?: "info" | "success" | "warning" | "error";
      title?: string;
      message: string;
      duration?: number;
    }) => void;
  };
};

type PluginOptions = Record<string, unknown> | undefined;

function httpGet(urlStr: string, timeoutMs = 3000): Promise<{ status: number }> {
  const urlObj = new URL(urlStr);
  const isHttps = urlObj.protocol === "https:";
  const mod = isHttps ? https : http;

  return new Promise((resolve, reject) => {
    const options: http.RequestOptions = {
      hostname: urlObj.hostname,
      port: urlObj.port
        ? parseInt(urlObj.port, 10)
        : isHttps ? 443 : 80,
      path: urlObj.pathname + urlObj.search,
      method: "GET",
      headers: {
        "Content-Type": "application/json",
      },
    };

    const req = mod.request(options, (res) => {
      clearTimeout(timer);
      resolve({ status: res.statusCode ?? 0 });
      res.resume();
    });

    const timer = setTimeout(() => {
      req.destroy(new Error(`timeout ${timeoutMs}ms`));
    }, timeoutMs);

    req.on("error", (e) => {
      clearTimeout(timer);
      reject(e);
    });

    req.end();
  });
}

const tui = async (
  api: TuiPluginApi,
  options: PluginOptions,
): Promise<void> => {
  const cfg: TuiConfig = {
    url: (options?.url as string) ?? "http://127.0.0.1:8760",
  };

  try {
    const res = await httpGet(`${cfg.url}/api/health`);
    if (res.status >= 200 && res.status < 300) {
      api.ui.toast({
        variant: "success",
        title: "Changez",
        message: `Connected to ${cfg.url}`,
        duration: 2000,
      });
    } else {
      api.ui.toast({
        variant: "warning",
        title: "Changez",
        message: `Service responded with ${res.status}`,
        duration: 3000,
      });
    }
  } catch {
    api.ui.toast({
      variant: "error",
      title: "Changez",
      message: `Cannot reach service at ${cfg.url}`,
      duration: 4000,
    });
  }

  let lastContent = '';
  let silentUntil = 0;

  const statusPath = path.join(process.cwd(), '.opencode', '.changez-status.json');

  setInterval(() => {
    try {
      const content = fs.readFileSync(statusPath, 'utf-8');
      if (content !== lastContent) {
        lastContent = content;
        const data = JSON.parse(content);

        if (Date.now() < silentUntil) return;
        silentUntil = Date.now() + 30000;

        const fileNames = data.files
          .map((f: { path: string }) => path.basename(f.path))
          .join(', ');

        api.ui.toast({
          variant: 'success',
          title: 'Changez',
          message: `${data.captured} captured: ${fileNames}`,
          duration: 3000,
        });
      }
    } catch {
      // 文件不存在或读取失败，忽略
    }
  }, 2000);
};

export default {
  id: "changez-tui",
  tui,
};
