## 插件代码结构

```typescript
// changez.ts
import * as fs from "node:fs"
import * as path from "node:path"
import * as http from "node:http"
import * as https from "node:https"

type ChangezConfig = {
  url: string;
  token?: string;
  source?: string;
  project?: { name?: string };
  logLevel?: "debug" | "info" | "warn" | "error";
}

const LOG_LEVELS = { error: 0, warn: 1, info: 2, debug: 3 }

// ── session → model 缓存 ──────────────────
const sessionModels = new Map<string, string>()

// ── HTTP 请求辅助（5s 超时） ──────────────
function httpRequest(
  cfg: ChangezConfig,
  method: string,
  pathStr: string,
  body?: object,
): Promise<{ status: number; json?: object }> {
  const urlObj = new URL(pathStr, cfg.url)
  const isHttps = urlObj.protocol === "https:"
  const mod = isHttps ? https : http

  return new Promise((resolve, reject) => {
    const payload = body ? JSON.stringify(body) : undefined
    const options = {
      hostname: urlObj.hostname,
      port: urlObj.port || (isHttps ? 443 : 80),
      path: urlObj.pathname + urlObj.search,
      method,
      headers: {
        "Content-Type": "application/json",
        ...(cfg.token ? { Authorization: `Bearer ${cfg.token}` } : {}),
      },
    }

    const req = mod.request(options, (res) => {
      clearTimeout(timer)
      let data = ""
      res.on("data", (chunk) => (data += chunk))
      res.on("end", () => {
        let json: object | undefined
        try { json = JSON.parse(data) } catch {}
        resolve({ status: res.statusCode ?? 0, json })
      })
    })

    const timer = setTimeout(() => {
      req.destroy(new Error("timeout 5s"))
    }, 5000)

    req.on("error", (e) => { clearTimeout(timer); reject(e) })

    if (payload) req.write(payload)
    req.end()
  })
}

// ── 路径提取辅助函数 ──────────────────────
function pickFilePath(args: any): string | undefined { ... }
function parsePatchTargets(patchText: string): Array<{ path: string; action: string }> { ... }
function extractRmPaths(command: string): string[] { ... }
function collectMultieditPaths(args: any): string[] { ... }

// ── 插件入口 ──────────────────────────────
export const ChangezPlugin = async (
  { client, directory }: PluginInput,
  options?: Record<string, unknown>,
) => {
  const cfg: ChangezConfig = {
    url: (options?.url as string) ?? "http://127.0.0.1:8111",
    token: (options?.token as string) ?? "",
    source: (options?.source as string) ?? "opencode",
    project: options?.project as ChangezConfig["project"],
    logLevel: (options?.logLevel as ChangezConfig["logLevel"]) ?? "info",
  }

  const projectRoot = path.resolve(directory)
  const projectName = cfg.project?.name ?? path.basename(projectRoot)

  // ── Logger ──────────────────────────────
  const log = (level: string, message: string, extra?: object) => {
    if (LOG_LEVELS[level] > LOG_LEVELS[cfg.logLevel]) return
    void client.app.log({ body: { service: "changez", level, message, ...extra } })
  }

  log("info", `loaded (${cfg.url}, project: ${projectName})`)

  // ── 自动注册 project ───────────────────
  try {
    const res = await httpRequest(cfg, "POST", "/api/projects", {
      rootPath: projectRoot,
      name: projectName,
    })
    if (res.status === 201) {
      log("info", `project registered: ${projectName}`)
    } else if (res.status !== 409) {
      log("warn", `project registration failed: ${res.status}`)
    }
  } catch (e) {
    log("warn", `project registration error: ${String(e)}`)
  }

  return {
    // 记录 model
    "chat.message": async (input, _output) => {
      if (input.model) {
        sessionModels.set(
          input.sessionID,
          `${input.model.providerID}/${input.model.modelID}`,
        )
      }
    },

    // 文件修改后上报
    "tool.execute.after": async (input, _output) => {
      const { tool, sessionID } = input
      const args = input.args
      const model = sessionModels.get(sessionID) ?? ""

      // 根据工具类型提取文件路径 + action
      let filePaths: Array<{ path: string; action: string }> = []

      if (tool === "write") {
        const fp = pickFilePath(args)
        if (fp) filePaths.push({ path: fp, action: "update" })
      } else if (tool === "edit") {
        const fp = pickFilePath(args)
        if (fp) filePaths.push({ path: fp, action: "update" })
      } else if (tool === "multiedit") {
        const paths = collectMultieditPaths(args)
        filePaths = paths.map(p => ({ path: p, action: "update" }))
      } else if (tool === "apply_patch") {
        const patchText = typeof args?.patchText === "string"
          ? args.patchText
          : typeof args?.patch === "string"
            ? args.patch
            : ""
        filePaths = parsePatchTargets(patchText)
      } else if (tool === "bash") {
        const cmd = typeof args?.command === "string" && args.command != null
          ? args.command
          : typeof args?.bash_command === "string" && args.bash_command != null
            ? args.bash_command
            : ""
        const rmPaths = extractRmPaths(cmd)
        filePaths = rmPaths.map(p => ({ path: p, action: "delete" }))
      }

      if (filePaths.length === 0) return

      // 读取文件内容
      const files: Array<{ path: string; content: string; action: string }> = []
      for (const { path: fp, action } of filePaths) {
        const absPath = path.isAbsolute(fp)
          ? path.normalize(fp)
          : path.normalize(path.join(projectRoot, fp))

        if (action === "delete") {
          // delete 不需要内容
          files.push({ path: absPath, content: "", action })
          continue
        }

        try {
          const stat = fs.statSync(absPath)
          if (stat.size > 10 * 1024 * 1024) {  // 10MB
            log("debug", `skip large file (>10MB): ${absPath}`)
            continue
          }
          const content = fs.readFileSync(absPath, "utf8")
          files.push({ path: absPath, content, action })
        } catch (e) {
          log("debug", `read failed: ${absPath}: ${String(e)}`)
        }
      }

      if (files.length === 0) return

      // 异步上报（不阻塞）
      httpRequest(cfg, "POST", "/api/snapshot", {
        source: cfg.source,
        sessionId: sessionID,
        model,
        files,
      }).then(res => {
        log("debug", `snapshot sent: ${files.length} file(s)`, { tool, sessionID })
        if (res.status >= 400) {
          log("warn", `snapshot failed: ${res.status}`)
        }
      }).catch(() => {
        log("warn", "snapshot request error")
      })
    },
  }
}
```

