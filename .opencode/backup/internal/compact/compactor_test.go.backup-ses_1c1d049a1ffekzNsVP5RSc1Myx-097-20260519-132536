// TestCompactChainTooShort 测试 delta 链长度不足时返回 false
func TestCompactChainTooShort(t *testing.T) {
	f := setupCompactTest(t, 5) // MaxDeltaChain = 5

	// 创建 blob 版本作为基础
	blobContent := []byte("initial content")
	blobVersionID := f.createBlobVersion(t, blobContent)

	// 只创建 2 个 delta 版本（小于 MaxDeltaChain=5）
	dmp := diffmatchpatch.New()
	diffs1 := dmp.DiffMain(string(blobContent), string(blobContent)+"\nadded line 1", false)
	delta1ID := f.createDeltaVersion(t, blobVersionID, diffs1)

	content2 := string(blobContent) + "\nadded line 1"
	diffs2 := dmp.DiffMain(content2, content2+"\nadded line 2", false)
	f.createDeltaVersion(t, delta1ID, diffs2)

	// delta 链长度 = 2 < 5，不应触发 compact
	compacted, err := f.compactor.CheckAndCompact(f.fileID)
	require.NoError(t, err)
	assert.False(t, compacted)
}

// TestCompactTriggersOnLongChain 测试 delta 链长度达到阈值时触发 compact
func TestCompactTriggersOnLongChain(t *testing.T) {
	maxChain := 3
	f := setupCompactTest(t, maxChain)

	// 创建 blob 版本作为基础
	blobContent := []byte("initial content")
	blobVersionID := f.createBlobVersion(t, blobContent)

	// 创建 N 个 delta 版本，N >= MaxDeltaChain
	dmp := diffmatchpatch.New()
	currentContent := string(blobContent)
	prevVersionID := blobVersionID

	for i := 0; i < maxChain; i++ {
		newContent := currentContent + "\nline " + string(rune('A'+i))
		diffs := dmp.DiffMain(currentContent, newContent, false)
		prevVersionID = f.createDeltaVersion(t, prevVersionID, diffs)
		currentContent = newContent
	}

	// delta 链长度 = 3 >= 3，应触发 compact
	compacted, err := f.compactor.CheckAndCompact(f.fileID)
	require.NoError(t, err)
	assert.True(t, compacted)

	// 验证最新版本现在是 blob 模式
	latest, err := f.db.GetLatestVersion(f.fileID)
	require.NoError(t, err)
	require.NotNil(t, latest)

	assert.Equal(t, "blob", latest["storageMode"].(string))
	assert.NotNil(t, latest["blobHash"])
	assert.Nil(t, latest["deltaOffset"])

	// 验证可以读取正确的内容
	hash := latest["blobHash"].(*string)
	readContent, err := f.blobStore.Read(*hash)
	require.NoError(t, err)
	assert.Equal(t, currentContent, string(readContent))
}

// TestCompactLatestConvertsToBlob 测试 compactLatest 正确转换版本
func TestCompactLatestConvertsToBlob(t *testing.T) {
	f := setupCompactTest(t, 2)

	// 创建 blob 版本
	blobContent := []byte("base content")
	blobVersionID := f.createBlobVersion(t, blobContent)

	// 创建 delta 版本
	dmp := diffmatchpatch.New()
	newContent := string(blobContent) + "\nappended"
	diffs := dmp.DiffMain(string(blobContent), newContent, false)
	deltaVersionID := f.createDeltaVersion(t, blobVersionID, diffs)

	// 再创建一个 delta 版本
	newContent2 := newContent + "\nmore"
	diffs2 := dmp.DiffMain(newContent, newContent2, false)
	f.createDeltaVersion(t, deltaVersionID, diffs2)

	// 触发 compact
	compacted, err := f.compactor.CheckAndCompact(f.fileID)
	require.NoError(t, err)
	assert.True(t, compacted)

	// 验证最新版本已转换为 blob
	latest, err := f.db.GetLatestVersion(f.fileID)
	require.NoError(t, err)
	require.NotNil(t, latest)

	assert.Equal(t, "blob", latest["storageMode"].(string))
	hash := latest["blobHash"].(*string)
	require.NotNil(t, hash)

	// 验证内容正确
	readContent, err := f.blobStore.Read(*hash)
	require.NoError(t, err)
	assert.Equal(t, newContent2, string(readContent))
}

