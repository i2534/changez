// TestRebuildLongDeltaChain 测试长 delta 链的重建
func TestRebuildLongDeltaChain(t *testing.T) {
	f := setupCompactTest(t, 100)

	// 创建基础 blob
	baseContent := "start\n"
	blobVersionID := f.createBlobVersion(t, []byte(baseContent))

	// 创建长 delta 链
	dmp := diffmatchpatch.New()
	currentContent := baseContent
	prevVersionID := blobVersionID

	for i := 0; i < 10; i++ {
		newContent := currentContent + "line" + string(rune('0'+i)) + "\n"
		diffs := dmp.DiffMain(currentContent, newContent, false)
		prevVersionID = f.createDeltaVersion(t, prevVersionID, diffs)
		currentContent = newContent
	}

	// 获取最新版本并重建
	latest, err := f.db.GetLatestVersion(f.fileID)
	require.NoError(t, err)
	require.NotNil(t, latest)

	rebuilt, err := f.compactor.rebuildFromDeltaChain(latest)
	require.NoError(t, err)
	assert.Equal(t, currentContent, string(rebuilt))
}

// ========== Run() Tests ==========

func TestRun_Disabled(t *testing.T) {
	cfg := &config.CompactCfg{Enabled: false}
	database, bs, ds, fileMuMap := createCompactStores(t)
	c := New(database, bs, ds, cfg, testLogger, fileMuMap)

	// When disabled, Run should return immediately
	ctx, cancel := context.WithTimeout(context.Background(), 100*time.Millisecond)
	defer cancel()

	done := make(chan struct{})
	go func() {
		c.Run(ctx)
		close(done)
	}()
	select {
	case <-done:
		// Run returned, good
	case <-time.After(time.Second):
		t.Fatal("Run() should return immediately when disabled")
	}
}

func TestRun_InvalidInterval(t *testing.T) {
	cfg := &config.CompactCfg{Enabled: true, Interval: "bad"}
	database, bs, ds, fileMuMap := createCompactStores(t)
	c := New(database, bs, ds, cfg, testLogger, fileMuMap)

	// Invalid interval should log error and return
	ctx, cancel := context.WithTimeout(context.Background(), 100*time.Millisecond)
	defer cancel()

	done := make(chan struct{})
	go func() {
		c.Run(ctx)
		close(done)
	}()
	select {
	case <-done:
		// Run returned after logging error
	case <-time.After(time.Second):
		t.Fatal("Run() should return when interval is invalid")
	}
}

func TestRun_ContextCancelled(t *testing.T) {
	cfg := &config.CompactCfg{Enabled: true, Interval: "1h"}
	database, bs, ds, fileMuMap := createCompactStores(t)
	c := New(database, bs, ds, cfg, testLogger, fileMuMap)

	// Cancelled context should stop Run
	ctx, cancel := context.WithCancel(context.Background())
	cancel() // Immediately cancel

	done := make(chan struct{})
	go func() {
		c.Run(ctx)
		close(done)
	}()
	select {
	case <-done:
		// Run exited from cancelled context
	case <-time.After(time.Second):
		t.Fatal("Run() should exit when context is cancelled")
	}
}

// createCompactStores is a helper that creates DB and stores without fixture
func createCompactStores(t *testing.T) (*db.DB, *storage.BlobStore, *storage.DeltaStore, *sync.Map) {
	t.Helper()
	dir := t.TempDir()
	database, err := db.Open(dir)
	require.NoError(t, err)
	bs := storage.NewBlobStore(dir)
	require.NoError(t, bs.EnsureDir())
	ds := storage.NewDeltaStore(dir)
	require.NoError(t, ds.EnsureDir())
	return database, bs, ds, &sync.Map{}
}

// TestCompactIdempotent 测试 compact 操作是幂等的
func TestCompactIdempotent(t *testing.T) {
	f := setupCompactTest(t, 2)

	// 创建版本链
	blobVersionID := f.createBlobVersion(t, []byte("content"))
	dmp := diffmatchpatch.New()
	diffs := dmp.DiffMain("content", "content\nv1", false)
	delta1ID := f.createDeltaVersion(t, blobVersionID, diffs)
	diffs2 := dmp.DiffMain("content\nv1", "content\nv1\nv2", false)
	f.createDeltaVersion(t, delta1ID, diffs2)

	// 第一次 compact
	compacted, err := f.compactor.CheckAndCompact(f.fileID)
	require.NoError(t, err)
	assert.True(t, compacted)

	// 第二次 compact（已经是 blob）
	compacted2, err := f.compactor.CheckAndCompact(f.fileID)
	require.NoError(t, err)
	assert.False(t, compacted2)
}
