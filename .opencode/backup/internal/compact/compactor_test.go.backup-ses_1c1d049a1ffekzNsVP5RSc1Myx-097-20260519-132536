// TestCompactMultipleFiles 测试多个文件的 compact 互不影响
func TestCompactMultipleFiles(t *testing.T) {
	f := setupCompactTest(t, 2)

	// 为第一个文件创建版本链
	blobVersionID := f.createBlobVersion(t, []byte("file1 content"))
	dmp := diffmatchpatch.New()
	diffs := dmp.DiffMain("file1 content", "file1 content\nmodified", false)
	delta1ID := f.createDeltaVersion(t, blobVersionID, diffs)
	diffs2 := dmp.DiffMain("file1 content\nmodified", "file1 content\nmodified\nagain", false)
	f.createDeltaVersion(t, delta1ID, diffs2)

	// 创建第二个文件
	fileID2, err := f.db.UpsertFile(f.projectID, "/test/path/file2.txt")
	require.NoError(t, err)

	// 为第二个文件创建版本链
	hash2, err := f.blobStore.Store([]byte("file2 content"))
	require.NoError(t, err)
	versionID2, err := f.db.CreateVersion(fileID2, "blob", &hash2, nil, nil, "update", f.sourceID)
	require.NoError(t, err)
	err = f.db.UpdateLatestVersion(fileID2, versionID2)
	require.NoError(t, err)

	// compact 第一个文件
	compacted, err := f.compactor.CheckAndCompact(f.fileID)
	require.NoError(t, err)
	assert.True(t, compacted)

	// 第二个文件仍是 blob，不应触发 compact
	compacted2, err := f.compactor.CheckAndCompact(fileID2)
	require.NoError(t, err)
	assert.False(t, compacted2)
}

