// TestCompactEmptyFile 测试空文件的 compact
func TestCompactEmptyFile(t *testing.T) {
	f := setupCompactTest(t, 2)

	// 创建空 blob 版本
	blobVersionID := f.createBlobVersion(t, []byte{})

	// 创建 delta 版本
	dmp := diffmatchpatch.New()
	diffs := dmp.DiffMain("", "new content", false)
	delta1ID := f.createDeltaVersion(t, blobVersionID, diffs)

	// 再创建一个 delta 版本
	diffs2 := dmp.DiffMain("new content", "new content\nmore", false)
	f.createDeltaVersion(t, delta1ID, diffs2)

	// 触发 compact
	compacted, err := f.compactor.CheckAndCompact(f.fileID)
	require.NoError(t, err)
	assert.True(t, compacted)

	// 验证内容正确
	latest, err := f.db.GetLatestVersion(f.fileID)
	require.NoError(t, err)
	hash := latest["blobHash"].(*string)
	require.NotNil(t, hash)

	readContent, err := f.blobStore.Read(*hash)
	require.NoError(t, err)
	assert.Equal(t, "new content\nmore", string(readContent))
}

