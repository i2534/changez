// compactFixture 集成测试的测试夹具
type compactFixture struct {
	compactor  *Compactor
	db         *db.DB
	blobStore  *storage.BlobStore
	deltaStore *storage.DeltaStore
	fileMuMap  *sync.Map
	projectID  int64
	fileID     int64
	sourceID   int64
}

// setupCompactTest 创建测试夹具
func setupCompactTest(t *testing.T, maxDeltaChain int) *compactFixture {
	t.Helper()
	dir := t.TempDir()

	database, err := db.Open(dir)
	require.NoError(t, err)

	bs := storage.NewBlobStore(dir)
	err = bs.EnsureDir()
	require.NoError(t, err)

	ds := storage.NewDeltaStore(dir)
	err = ds.EnsureDir()
	require.NoError(t, err)

	cfg := &config.CompactCfg{
		Enabled:                true,
		MaxDeltaChain:          maxDeltaChain,
		DeltaCompressThreshold: 512,
	}
	fileMuMap := &sync.Map{}

	c := New(database, bs, ds, cfg, testLogger, fileMuMap)

	// 创建项目
	projectID, err := database.CreateProject(context.Background(), "test-project", "/test/path", "{}")
	require.NoError(t, err)

	// 创建文件
	fileID, err := database.UpsertFile(context.Background(), projectID, "/test/path/file.txt")
	require.NoError(t, err)

	// 获取 source ID
	sourceID, err := database.GetSourceIDByName(context.Background(), "human")
	require.NoError(t, err)

	return &compactFixture{
		compactor:  c,
		db:         database,
		blobStore:  bs,
		deltaStore: ds,
		fileMuMap:  fileMuMap,
		projectID:  projectID,
		fileID:     fileID,
		sourceID:   sourceID,
	}
}

// createBlobVersion 创建一个 blob 模式的版本
func (f *compactFixture) createBlobVersion(t *testing.T, content []byte) int64 {
	t.Helper()
	hash, err := f.blobStore.Store(content)
	require.NoError(t, err)

	versionID, err := f.db.CreateVersion(context.Background(), f.fileID, "blob", &hash, nil, nil, "update", f.sourceID)
	require.NoError(t, err)

	err = f.db.UpdateLatestVersion(context.Background(), f.fileID, versionID)
	require.NoError(t, err)

	return versionID
}

// createDeltaVersion 创建一个 delta 模式的版本
func (f *compactFixture) createDeltaVersion(t *testing.T, baseVersionID int64, diffs []diffmatchpatch.Diff) int64 {
	t.Helper()
	offset, _, err := f.deltaStore.Append(f.fileID, 0, diffs, nil, 1024)
	require.NoError(t, err)

	versionID, err := f.db.CreateVersion(context.Background(), f.fileID, "delta", nil, &offset, &baseVersionID, "update", f.sourceID)
	require.NoError(t, err)

	err = f.db.UpdateLatestVersion(context.Background(), f.fileID, versionID)
	require.NoError(t, err)

	return versionID
}

