// TestRebuildFromDeltaChain 测试从 delta 链重建内容
func TestRebuildFromDeltaChain(t *testing.T) {
	f := setupCompactTest(t, 10)

	// 创建基础 blob
	baseContent := "line1\nline2\nline3\n"
	blobVersionID := f.createBlobVersion(t, []byte(baseContent))

	// 创建 delta 链
	dmp := diffmatchpatch.New()
	content1 := baseContent + "line4\n"
	diffs1 := dmp.DiffMain(baseContent, content1, false)
	delta1ID := f.createDeltaVersion(t, blobVersionID, diffs1)

	content2 := content1 + "line5\n"
	diffs2 := dmp.DiffMain(content1, content2, false)
	delta2ID := f.createDeltaVersion(t, delta1ID, diffs2)

	content3 := content2 + "line6\n"
	diffs3 := dmp.DiffMain(content2, content3, false)
	delta3ID := f.createDeltaVersion(t, delta2ID, diffs3)

	// 获取最新版本
	latest, err := f.db.GetVersion(delta3ID)
	require.NoError(t, err)

	// 从 delta 链重建内容
	rebuilt, err := f.compactor.rebuildFromDeltaChain(latest)
	require.NoError(t, err)
	assert.Equal(t, content3, string(rebuilt))
}

