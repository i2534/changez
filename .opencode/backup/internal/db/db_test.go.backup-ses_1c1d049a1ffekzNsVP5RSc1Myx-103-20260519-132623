func TestGetStats_ReturnsCorrectCounts(t *testing.T) {
	db := setupDB(t)

	// 创建项目
	projectID := createTestProject(t, db, "test-project", "/project")

	// 创建文件
	fileID, _ := db.UpsertFile(projectID, "/project/src/main.go")

	// 创建版本
	_, _ = db.CreateVersion(fileID, "blob", nil, nil, nil, "update", 1)
	_, _ = db.CreateVersion(fileID, "blob", nil, nil, nil, "update", 2)

	stats, err := db.GetStats()
	require.NoError(t, err)

	assert.Equal(t, 1, stats["projects"])
	assert.Equal(t, 1, stats["files"])
	assert.Equal(t, 2, stats["versions"])

	// 验证 sources breakdown
	sources := stats["sources"].(map[string]int)
	assert.Equal(t, 1, sources["opencode"])
	assert.Equal(t, 1, sources["claude-code"])
	assert.Equal(t, 0, sources["cursor"])
	assert.Equal(t, 0, sources["human"])
}

func TestGetStats_EmptyDatabase(t *testing.T) {
	db := setupDB(t)

	stats, err := db.GetStats()
	require.NoError(t, err)

	assert.Equal(t, 0, stats["projects"])
	assert.Equal(t, 0, stats["files"])
	assert.Equal(t, 0, stats["versions"])

	sources := stats["sources"].(map[string]int)
	// 所有 source 的版本数都应该是 0
	for _, count := range sources {
		assert.Equal(t, 0, count)
	}
}

