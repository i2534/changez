	projectID := createTestProject(t, db, "test-project", "/project")
	fileID, _ := db.UpsertFile(projectID, "/project/src/main.go")

	// 创建 5 个版本
	for i := 0; i < 5; i++ {
		_, err := db.CreateVersion(fileID, "blob", nil, nil, nil, "update", 1)
		require.NoError(t, err)
	}

	// 第一页
	page1, err := db.ListVersions(fileID, nil, nil, nil, nil, 2, 0)
	require.NoError(t, err)
	assert.Len(t, page1, 2)

	// 第二页
	page2, err := db.ListVersions(fileID, nil, nil, nil, nil, 2, 2)
	require.NoError(t, err)
	assert.Len(t, page2, 2)

	// 第三页
	page3, err := db.ListVersions(fileID, nil, nil, nil, nil, 2, 4)
	require.NoError(t, err)
	assert.Len(t, page3, 1)
}

func TestCountVersions_ReturnsCorrectCount(t *testing.T) {
