// setupDB 创建一个临时数据库用于测试
func setupDB(t *testing.T) *DB {
	t.Helper()
	dir := t.TempDir()
	db, err := Open(dir)
	require.NoError(t, err, "Open should succeed")
	t.Cleanup(func() {
		db.Close()
	})
	return db
}

// createTestProject 创建测试项目并返回 ID
func createTestProject(t *testing.T, db *DB, name, rootPath string) int64 {
	t.Helper()
	id, err := db.CreateProject(context.Background(), name, rootPath, "{}")
	require.NoError(t, err, "CreateProject should succeed")
	return id
}

