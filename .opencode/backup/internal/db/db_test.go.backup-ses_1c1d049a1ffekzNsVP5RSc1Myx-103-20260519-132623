func TestCreateVersion_UpdateLatestVersion_GetLatestVersion_Chain(t *testing.T) {
	db := setupDB(t)
	projectID := createTestProject(t, db, "test-project", "/project")
	fileID, _ := db.UpsertFile(projectID, "/project/src/main.go")

	// 创建版本
	blobHash := "hash1"
	versionID, err := db.CreateVersion(fileID, "blob", &blobHash, nil, nil, "update", 1)
	require.NoError(t, err)

	// 更新 latest_version_id
	err = db.UpdateLatestVersion(fileID, versionID)
	require.NoError(t, err)

	// 获取最新版本
	latest, err := db.GetLatestVersion(fileID)
	require.NoError(t, err)
	require.NotNil(t, latest)
	assert.Equal(t, versionID, latest["id"])
}

func TestUpdateVersionStorage_UpdatesFields(t *testing.T) {
	db := setupDB(t)
	projectID := createTestProject(t, db, "test-project", "/project")
	fileID, _ := db.UpsertFile(projectID, "/project/src/main.go")

	versionID, _ := db.CreateVersion(fileID, "blob", nil, nil, nil, "update", 1)

	// 更新存储信息
	newBlobHash := "newhash"
	var deltaOffset int64 = 1024
	err := db.UpdateVersionStorage(versionID, "delta", &newBlobHash, &deltaOffset)
	require.NoError(t, err)

	// 验证更新
	version, err := db.GetVersion(versionID)
	require.NoError(t, err)
	assert.Equal(t, "delta", version["storageMode"])
	assert.Equal(t, &newBlobHash, version["blobHash"])
	assert.Equal(t, &deltaOffset, version["deltaOffset"])
}

