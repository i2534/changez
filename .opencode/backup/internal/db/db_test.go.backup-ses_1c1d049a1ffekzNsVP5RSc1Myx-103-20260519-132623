// Query Tests
// ========================================

func TestQuery_ExecutesArbitraryQuery(t *testing.T) {
	db := setupDB(t)

	rows, err := db.Query("SELECT name FROM sources ORDER BY id")
	require.NoError(t, err)
	defer rows.Close()

	var names []string
	for rows.Next() {
		var name string
		require.NoError(t, rows.Scan(&name))
		names = append(names, name)
	}

	assert.Equal(t, []string{"opencode", "claude-code", "cursor", "human"}, names)
}
