// ProcessSnapshot 处理快照请求（不依赖 HTTP），供 HTTP handler 和 MCP handler 共用。
func (h *Handler) ProcessSnapshot(req *SnapshotRequest) *SnapshotResponse {
	results := make([]SnapshotResult, len(req.Files))
	summary := SnapshotSummary{}

	sourceID, ok := h.SourceIDs[req.Source]
	if !ok {
		return &SnapshotResponse{
			Results: results,
			Summary: SnapshotSummary{Errors: len(req.Files)},
		}
	}

	dmpLocal := diffmatchpatch.New()

	for i, sf := range req.Files {
		if sf.Path == "" {
			results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: "path 不能为空"}
			summary.Errors++
			continue
		}

		project, err := h.DB.FindProjectByPath(sf.Path)
		if err != nil {
			results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: err.Error()}
			summary.Errors++
			continue
		}

		relPath := sf.Path
		rootPath := project["rootPath"].(string)
		if len(sf.Path) > len(rootPath) && sf.Path[:len(rootPath)] == rootPath {
			relPath = strings.TrimPrefix(sf.Path[len(rootPath):], "/")
		}

		fileID, err := h.DB.UpsertFile(project["id"].(int64), relPath)
		if err != nil {
			results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("文件注册失败: %v", err)}
			summary.Errors++
			continue
		}

		fileMu := h.getFileLock(fileID)
		fileMu.Lock()
		func() {
			defer fileMu.Unlock()

			latestVer, err := h.DB.GetLatestVersion(fileID)
			if err != nil {
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("查询最新版本失败: %v", err)}
				summary.Errors++
				return
			}

			action := strings.ToLower(sf.Action)
			switch action {
			case "create", "update", "delete":
				if action == "create" && latestVer != nil {
					action = "update"
				}
				if action == "update" && latestVer == nil {
					action = "create"
				}
			default:
				if latestVer == nil {
					action = "create"
				} else {
					action = "update"
				}
			}

			if action == "delete" {
				if latestVer == nil {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: "文件无版本记录，无法删除"}
					summary.Errors++
					return
				}
				if latestVer["action"].(string) == "delete" {
					results[i] = SnapshotResult{Path: sf.Path, Status: "unchanged"}
					summary.Unchanged++
					return
				}

				baseVerID := latestVer["id"].(int64)
				versionID, err := h.DB.CreateVersion(
					fileID, "delete", nil, nil, &baseVerID, "delete", sourceID,
				)
				if err != nil {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("写入删除版本失败: %v", err)}
					summary.Errors++
					return
				}
				if err := h.DB.UpdateLatestVersion(fileID, versionID); err != nil {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("更新 latest_version 失败: %v", err)}
					summary.Errors++
					return
				}
				results[i] = SnapshotResult{Path: sf.Path, Status: "captured", VersionID: &versionID}
				summary.Captured++
				return
			}

			content := sf.Content
			if int64(len(content)) > h.Config.Storage.MaxFileSize {
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("文件大小 %d 超过限制 %d", len(content), h.Config.Storage.MaxFileSize)}
				summary.Errors++
				return
			}

			contentBytes := []byte(content)
			contentHash := storage.ContentHash(contentBytes)

			if latestVer != nil {
				if latestVer["action"].(string) == "delete" {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: "文件已被删除，无法更新"}
					summary.Errors++
					return
				}

				if latestVer["storageMode"].(string) == "blob" {
					if bh := latestVer["blobHash"]; bh != nil && bh.(string) == contentHash {
						results[i] = SnapshotResult{Path: sf.Path, Status: "unchanged"}
						summary.Unchanged++
						return
					}
				}

				prevContent, err := h.RebuildContent(latestVer)
				if err != nil {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("重建上一版本内容失败: %v", err)}
					summary.Errors++
					return
				}
				prevHash := storage.ContentHash(prevContent)
				if prevHash == contentHash {
					results[i] = SnapshotResult{Path: sf.Path, Status: "unchanged"}
					summary.Unchanged++
					return
				}
			}

			if latestVer == nil {
				hash, err := h.BlobStore.Store(contentBytes)
				if err != nil {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("存储 blob 失败: %v", err)}
					summary.Errors++
					return
				}
				versionID, err := h.DB.CreateVersion(
					fileID, "blob", &hash, nil, nil, action, sourceID,
				)
				if err != nil {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("写入版本记录失败: %v", err)}
					summary.Errors++
					return
				}
				if err := h.DB.UpdateLatestVersion(fileID, versionID); err != nil {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("更新 latest_version 失败: %v", err)}
					summary.Errors++
					return
				}
				results[i] = SnapshotResult{Path: sf.Path, Status: "captured", VersionID: &versionID}
				summary.Captured++
				return
			}

			prevContent, err := h.RebuildContent(latestVer)
			if err != nil {
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("重建上一版本内容失败: %v", err)}
				summary.Errors++
				return
			}

			diffs := dmpLocal.DiffMain(string(prevContent), content, true)
			diffs = dmpLocal.DiffCleanupSemantic(diffs)

			var meta *storage.DeltaMeta
			if req.SessionID != "" || req.Model != "" || sf.Message != "" {
				meta = &storage.DeltaMeta{
					SessionID: req.SessionID,
					Model:     req.Model,
					Message:   sf.Message,
				}
			}

			threshold := h.Config.Compact.DeltaCompressThreshold
			offset, _, err := h.DeltaStore.Append(fileID, 0, diffs, meta, threshold)
			if err != nil {
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("写入 delta 失败: %v", err)}
				summary.Errors++
				return
			}

			baseID := latestVer["id"].(int64)
			versionID, err := h.DB.CreateVersion(
				fileID, "delta", nil, &offset, &baseID, action, sourceID,
			)
			if err != nil {
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("写入版本记录失败: %v", err)}
				summary.Errors++
				return
			}
			if err := h.DB.UpdateLatestVersion(fileID, versionID); err != nil {
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("更新 latest_version 失败: %v", err)}
				summary.Errors++
				return
			}

			results[i] = SnapshotResult{Path: sf.Path, Status: "captured", VersionID: &versionID}
			summary.Captured++
		}()
	}

	return &SnapshotResponse{Results: results, Summary: summary}
}

// ProcessLog 处理版本历史查询。
func (h *Handler) ProcessLog(filePath, since, until, source, action string, limit, offset int) (*LogResponse, error) {
	project, err := h.DB.FindProjectByPath(filePath)
	if err != nil {
		return nil, fmt.Errorf("PROJECT_NOT_FOUND: %v", err)
	}

	relPath := filePath
	rootPath := project["rootPath"].(string)
	if len(filePath) > len(rootPath) && filePath[:len(rootPath)] == rootPath {
		relPath = strings.TrimPrefix(filePath[len(rootPath):], "/")
	}

	file, err := h.DB.GetFileByPath(project["id"].(int64), relPath)
	if err != nil {
		return nil, fmt.Errorf("FILE_NOT_FOUND: %v", err)
	}

	fileID := file["id"].(int64)

	var sourceID *int64
	if source != "" {
		sid, err := h.DB.GetSourceIDByName(source)
		if err != nil {
			return nil, fmt.Errorf("INVALID_REQUEST: 不支持的 source: %s", source)
		}
		sourceID = &sid
	}

	var act *string
	if action != "" {
		act = &action
	}

	var sincePtr, untilPtr *string
	if since != "" {
		sincePtr = &since
	}
	if until != "" {
		untilPtr = &until
	}

	versions, err := h.DB.ListVersions(fileID, sourceID, act, sincePtr, untilPtr, limit, offset)
	if err != nil {
		return nil, fmt.Errorf("INTERNAL_ERROR: 查询版本列表失败: %v", err)
	}

	total, err := h.DB.CountVersions(fileID)
	if err != nil {
		return nil, fmt.Errorf("INTERNAL_ERROR: 统计版本数失败: %v", err)
	}

	resultVersions := make([]LogVersionEntry, 0, len(versions))
	for _, v := range versions {
		entry := LogVersionEntry{
			VersionID: v["versionId"].(int64),
			Timestamp: v["timestamp"].(string),
			Source:    v["source"].(string),
			Action:    v["action"].(string),
		}

		storageMode := ""
		if sm, ok := v["storageMode"]; ok {
			storageMode = sm.(string)
		}

		if storageMode == "delta" {
			meta, err := h.readDeltaMeta(fileID, v["versionId"].(int64))
			if err == nil && meta != nil {
				entry.SessionID = meta.SessionID
				entry.Model = meta.Model
				entry.Message = meta.Message
			}
		}

		resultVersions = append(resultVersions, entry)
	}

	return &LogResponse{
		File:          filePath,
		Project:       project["name"].(string),
		TotalVersions: total,
		Versions:      resultVersions,
	}, nil
}

// ProcessRestore 处理版本恢复。
func (h *Handler) ProcessRestore(filePath string, versionID int64) (*RestoreResponse, error) {
	project, err := h.DB.FindProjectByPath(filePath)
	if err != nil {
		return nil, fmt.Errorf("PROJECT_NOT_FOUND: %v", err)
	}

	relPath := filePath
	rootPath := project["rootPath"].(string)
	if len(filePath) > len(rootPath) && filePath[:len(rootPath)] == rootPath {
		relPath = strings.TrimPrefix(filePath[len(rootPath):], "/")
	}

	file, err := h.DB.GetFileByPath(project["id"].(int64), relPath)
	if err != nil {
		return nil, fmt.Errorf("FILE_NOT_FOUND: %v", err)
	}

	fileID := file["id"].(int64)

	fileMu := h.getFileLock(fileID)
	fileMu.RLock()
	defer fileMu.RUnlock()

	ver, err := h.DB.GetVersion(versionID)
	if err != nil {
		return nil, fmt.Errorf("VERSION_NOT_FOUND: 版本 %d 不存在: %v", versionID, err)
	}

	if ver["fileID"].(int64) != fileID {
		return nil, fmt.Errorf("INVALID_REQUEST: 版本 %d 不属于该文件", versionID)
	}

	if ver["action"].(string) == "delete" {
		return nil, fmt.Errorf("INVALID_REQUEST: delete 版本无内容可恢复")
	}

	content, err := h.RebuildContent(ver)
	if err != nil {
		return nil, fmt.Errorf("CORRUPTED_DATA: 数据恢复失败: %v", err)
	}

	return &RestoreResponse{
		Path:      filePath,
		Version:   versionID,
		Timestamp: ver["changedAt"].(string),
		Content:   string(content),
	}, nil
}

// ProcessDiff 处理版本 diff。
func (h *Handler) ProcessDiff(filePath string, versionA, versionB int64) (*DiffResponse, error) {
	project, err := h.DB.FindProjectByPath(filePath)
	if err != nil {
		return nil, fmt.Errorf("PROJECT_NOT_FOUND: %v", err)
	}

	relPath := filePath
	rootPath := project["rootPath"].(string)
	if len(filePath) > len(rootPath) && filePath[:len(rootPath)] == rootPath {
		relPath = strings.TrimPrefix(filePath[len(rootPath):], "/")
	}

	file, err := h.DB.GetFileByPath(project["id"].(int64), relPath)
	if err != nil {
		return nil, fmt.Errorf("FILE_NOT_FOUND: %v", err)
	}

	fileID := file["id"].(int64)

	verA, err := h.DB.GetVersion(versionA)
	if err != nil {
		return nil, fmt.Errorf("VERSION_NOT_FOUND: 版本 %d 不存在: %v", versionA, err)
	}
	verB, err := h.DB.GetVersion(versionB)
	if err != nil {
		return nil, fmt.Errorf("VERSION_NOT_FOUND: 版本 %d 不存在: %v", versionB, err)
	}

	if verA["fileID"].(int64) != fileID {
		return nil, fmt.Errorf("INVALID_REQUEST: 版本 %d 不属于该文件", versionA)
	}
	if verB["fileID"].(int64) != fileID {
		return nil, fmt.Errorf("INVALID_REQUEST: 版本 %d 不属于该文件", versionB)
	}

	if verA["action"].(string) == "delete" {
		return nil, fmt.Errorf("INVALID_REQUEST: 版本 %d 为 delete 状态，无法参与 diff", versionA)
	}
	if verB["action"].(string) == "delete" {
		return nil, fmt.Errorf("INVALID_REQUEST: 版本 %d 为 delete 状态，无法参与 diff", versionB)
	}

	var diffs []diffmatchpatch.Diff
	isAdjacentDelta := false
	if verB["storageMode"].(string) == "delta" && verB["baseID"] != nil && verB["baseID"].(int64) == verA["id"].(int64) {
		offset := verB["deltaOffset"].(*int64)
		if offset != nil {
			_, readDiffs, _, err := h.DeltaStore.ReadEntry(fileID, *offset)
			if err == nil {
				diffs = readDiffs
				isAdjacentDelta = true
			}
		}
	}

	if !isAdjacentDelta {
		contentA, err := h.RebuildContent(verA)
		if err != nil {
			return nil, fmt.Errorf("CORRUPTED_DATA: 重建版本 %d 内容失败: %v", versionA, err)
		}
		contentB, err := h.RebuildContent(verB)
		if err != nil {
			return nil, fmt.Errorf("CORRUPTED_DATA: 重建版本 %d 内容失败: %v", versionB, err)
		}

		dmpLocal := diffmatchpatch.New()
		diffs = dmpLocal.DiffMain(string(contentA), string(contentB), true)
		diffs = dmpLocal.DiffCleanupSemantic(diffs)
	}

	return &DiffResponse{
		OldVersion: versionA,
		NewVersion: versionB,
		Diff:       RenderUnifiedDiff(diffs, filePath, filePath, verA["changedAt"].(string), verB["changedAt"].(string)),
	}, nil
}

// readDeltaMeta 从 delta entry 中读取 metadata。
func (h *Handler) readDeltaMeta(fileID, versionID int64) (*storage.DeltaMeta, error) {
	ver, err := h.DB.GetVersion(versionID)
	if err != nil {
		return nil, err
	}
	if ver["storageMode"].(string) != "delta" {
		return nil, nil
	}
	offset := ver["deltaOffset"]
	if offset == nil {
		return nil, nil
	}
	_, _, meta, err := h.DeltaStore.ReadEntry(fileID, offset.(int64))
	if err != nil {
		return nil, err
	}
	return meta, nil
}

// extractPathFromURL 从 URL 路径中提取文件路径。
func extractPathFromURL(urlPath, prefix, suffix string) string {
	if !strings.HasPrefix(urlPath, prefix) {
		return ""
	}
	path := strings.TrimPrefix(urlPath, prefix)
	if suffix != "" && strings.HasSuffix(path, suffix) {
		path = strings.TrimSuffix(path, suffix)
	}
	return path
}

// parseRestorePath 解析 restore URL 路径。
func parseRestorePath(urlPath string) (string, int64, error) {
	const prefix = "/api/files/"
	if !strings.HasPrefix(urlPath, prefix) {
		return "", 0, fmt.Errorf("无效的路径格式")
	}
	rest := urlPath[len(prefix):]
	const restoreSep = "/restore/"
	idx := strings.LastIndex(rest, restoreSep)
	if idx < 0 {
		return "", 0, fmt.Errorf("缺少 /restore/:version 部分")
	}
	path := rest[:idx]
	versionStr := rest[idx+len(restoreSep):]
	versionID, err := strconv.ParseInt(versionStr, 10, 64)
	if err != nil {
		return "", 0, fmt.Errorf("无效的版本号: %s", versionStr)
	}
	return path, versionID, nil
}

func NewHandler(database *db.DB, bs *storage.BlobStore, ds *storage.DeltaStore, cfg *config.Config, sourceIDs map[string]int64) *Handler {
	return &Handler{
		DB:         database,
		BlobStore:  bs,
		DeltaStore: ds,
		Config:     cfg,
		SourceIDs:  sourceIDs,
	}
}

func writeJSON(w http.ResponseWriter, status int, data any) {
	w.Header().Set("Content-Type", "application/json; charset=utf-8")
	w.WriteHeader(status)
	json.NewEncoder(w).Encode(data)
}

func writeError(w http.ResponseWriter, status int, code, message string) {
	resp := map[string]any{
		"error": map[string]string{
			"code":    code,
			"message": message,
		},
	}
	writeJSON(w, status, resp)
}
