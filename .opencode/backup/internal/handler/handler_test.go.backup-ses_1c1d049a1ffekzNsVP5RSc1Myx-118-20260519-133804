// ========== Helper Functions ==========

func int64ToStr(n int64) string {
	return strings.TrimSuffix(strings.TrimPrefix(string(mustMarshal(n)), "\""), "\"")
}

func mustMarshal(v any) []byte {
	b, _ := json.Marshal(v)
	return b
}
