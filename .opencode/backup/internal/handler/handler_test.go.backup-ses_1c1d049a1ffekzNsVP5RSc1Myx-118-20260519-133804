func TestReadDeltaMeta_WithMeta(t *testing.T) {
	h, _, _, _ := setupTest(t)
	createProject(t, h)

	// Create a snapshot with meta -> delta version
	req := &SnapshotRequest{Source: "human", SessionID: "sess-1", Model: "claude",
		Files: []SnapshotFile{{Path: "/home/user/proj/main.go", Content: "v1"}}}
	results := h.ProcessSnapshot(req)
	require.Len(t, results, 1)
	require.Equal(t, "captured", results[0].Status)
	// First snapshot is blob, not delta, so meta won't be in delta entry
	// Create second snapshot to get a delta with meta
	req2 := &SnapshotRequest{Source: "human", SessionID: "sess-2", Model: "gpt4",
		Files: []SnapshotFile{{Path: "/home/user/proj/main.go", Content: "v2 content updated"}}}
	results2 := h.ProcessSnapshot(req2)
	require.Len(t, results2, 1)
	require.Equal(t, "captured", results2[0].Status)

	// Get file info
	dbObj := h.DB
	project, err := dbObj.FindProjectByPath(context.Background(), "/home/user/proj/main.go")
	require.NoError(t, err)
	file, err := dbObj.GetFileByPath(context.Background(), project["id"].(int64), "main.go")
	require.NoError(t, err)
	fileID := file["id"].(int64)
	v2ID := *results2[0].VersionID

	meta, err := h.readDeltaMeta(fileID, v2ID)
	require.NoError(t, err)
	require.NotNil(t, meta)
	assert.Equal(t, "sess-2", meta.SessionID)
	assert.Equal(t, "gpt4", meta.Model)
}

// ========== rebuildFromDeltaChain Tests ==========

func TestRebuildFromDeltaChain(t *testing.T) {
	h, _, _, ds := setupTest(t)
	createProject(t, h)

	// Create blob + delta chain then rebuild from delta
	req1 := &SnapshotRequest{Source: "human", Files: []SnapshotFile{{Path: "/home/user/proj/main.go", Content: "base content"}}}
	results1 := h.ProcessSnapshot(req1)
	require.Len(t, results1, 1)
	v1ID := *results1[0].VersionID

	req2 := &SnapshotRequest{Source: "human", Files: []SnapshotFile{{Path: "/home/user/proj/main.go", Content: "base content\nline 2"}}}
	results2 := h.ProcessSnapshot(req2)
	require.Len(t, results2, 1)
	v2ID := *results2[0].VersionID

	req3 := &SnapshotRequest{Source: "human", Files: []SnapshotFile{{Path: "/home/user/proj/main.go", Content: "base content\nline 2\nline 3"}}}
	results3 := h.ProcessSnapshot(req3)
	require.Len(t, results3, 1)
	v3ID := *results3[0].VersionID

	// Get version 3 which is a delta and rebuild from it
	ver3, err := h.DB.GetVersion(v3ID)
	require.NoError(t, err)

	rebuilt, err := h.rebuildFromDeltaChain(ver3)
	require.NoError(t, err)
	assert.Equal(t, "base content\nline 2\nline 3", string(rebuilt))

	// Also rebuild version 2
	ver2, err := h.DB.GetVersion(v2ID)
	require.NoError(t, err)
	rebuilt2, err := h.rebuildFromDeltaChain(ver2)
	require.NoError(t, err)
	assert.Equal(t, "base content\nline 2", string(rebuilt2))

	// Rebuild version 1 (blob)
	ver1, err := h.DB.GetVersion(v1ID)
	require.NoError(t, err)
	rebuilt1, err := h.rebuildContent(ver1)
	require.NoError(t, err)
	assert.Equal(t, "base content", string(rebuilt1))

	_ = ds
}

