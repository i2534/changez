// ========== Diff Tests ==========

func TestDiff(t *testing.T) {
	h, _, _, _ := setupTest(t)
	createProject(t, h)

	// First snapshot
	body1 := `{"source":"human","files":[{"path":"/home/user/proj/main.go","content":"package main\nfunc main() {}"}]}`
	req := httptest.NewRequest(http.MethodPost, "/api/snapshot", strings.NewReader(body1))
	req.Header.Set("Content-Type", "application/json")
	w := httptest.NewRecorder()
	h.HandleSnapshot(w, req)
	require.Equal(t, http.StatusOK, w.Code)

	var resp1 SnapshotResponse
	require.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp1))
	fromID := resp1.Results[0].VersionID

	// Second snapshot with different content
	body2 := `{"source":"human","files":[{"path":"/home/user/proj/main.go","content":"package main\n\nfunc main() {\n\tfmt.Println(\"hello\")\n}"}]}`
	req2 := httptest.NewRequest(http.MethodPost, "/api/snapshot", strings.NewReader(body2))
	req2.Header.Set("Content-Type", "application/json")
	w2 := httptest.NewRecorder()
	h.HandleSnapshot(w2, req2)
	require.Equal(t, http.StatusOK, w2.Code)

	var resp2 SnapshotResponse
	require.NoError(t, json.Unmarshal(w2.Body.Bytes(), &resp2))
	toID := resp2.Results[0].VersionID

	// Diff
	req3 := httptest.NewRequest(http.MethodGet, "/api/files/home/user/proj/main.go/diff?from="+int64ToStr(*fromID)+"&to="+int64ToStr(*toID), nil)
	w3 := httptest.NewRecorder()
	h.HandleDiff(w3, req3)

	require.Equal(t, http.StatusOK, w3.Code)

	var diffResp map[string]any
	require.NoError(t, json.Unmarshal(w3.Body.Bytes(), &diffResp))
	require.Contains(t, diffResp, "diff")
	require.NotEmpty(t, diffResp["diff"])
}

func TestDiff_AdjacentDelta(t *testing.T) {
	h, _, _, _ := setupTest(t)
	createProject(t, h)

	// First snapshot
	body1 := `{"source":"human","files":[{"path":"/home/user/proj/main.go","content":"package main\nfunc main() {}"}]}`
	req := httptest.NewRequest(http.MethodPost, "/api/snapshot", strings.NewReader(body1))
	req.Header.Set("Content-Type", "application/json")
	w := httptest.NewRecorder()
	h.HandleSnapshot(w, req)
	require.Equal(t, http.StatusOK, w.Code)

	var resp1 SnapshotResponse
	require.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp1))
	fromID := resp1.Results[0].VersionID

	// Second snapshot (creates delta)
	body2 := `{"source":"human","files":[{"path":"/home/user/proj/main.go","content":"package main\n\nfunc main() {\n\tfmt.Println(\"hello\")\n}"}]}`
	req2 := httptest.NewRequest(http.MethodPost, "/api/snapshot", strings.NewReader(body2))
	req2.Header.Set("Content-Type", "application/json")
	w2 := httptest.NewRecorder()
	h.HandleSnapshot(w2, req2)
	require.Equal(t, http.StatusOK, w2.Code)

	var resp2 SnapshotResponse
	require.NoError(t, json.Unmarshal(w2.Body.Bytes(), &resp2))
	toID := resp2.Results[0].VersionID

	// Diff between adjacent versions should use delta optimization
	req3 := httptest.NewRequest(http.MethodGet, "/api/files/home/user/proj/main.go/diff?from="+int64ToStr(*fromID)+"&to="+int64ToStr(*toID), nil)
	w3 := httptest.NewRecorder()
	h.HandleDiff(w3, req3)

	require.Equal(t, http.StatusOK, w3.Code)
}

