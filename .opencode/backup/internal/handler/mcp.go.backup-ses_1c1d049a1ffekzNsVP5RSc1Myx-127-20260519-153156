// ProcessSnapshot 处理快照请求（非 HTTP 版本，给 MCP 用）。
func (h *Handler) ProcessSnapshot(req *SnapshotRequest) []SnapshotResult {
	ctx := context.Background()
	sourceID, ok := h.SourceIDs[req.Source]
	if !ok {
		return []SnapshotResult{{Path: "", Status: "error", Reason: fmt.Sprintf("不支持的 source: %s", req.Source)}}
	}

	if len(req.Files) == 0 {
		return []SnapshotResult{{Path: "", Status: "error", Reason: "files 不能为空"}}
	}

	results := make([]SnapshotResult, len(req.Files))
	dmp := diffmatchpatch.New()

	for i, sf := range req.Files {
		if sf.Path == "" {
			results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: "path 不能为空"}
			continue
		}

		project, err := h.DB.FindProjectByPath(ctx, sf.Path)
		if err != nil {
			results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: err.Error()}
			continue
		}

		relPath := sf.Path
		rootPath := project["rootPath"].(string)
		if len(sf.Path) > len(rootPath) && sf.Path[:len(rootPath)] == rootPath {
			relPath = strings.TrimPrefix(sf.Path[len(rootPath):], "/")
		}

		fileID, err := h.DB.UpsertFile(ctx, project["id"].(int64), relPath)
		if err != nil {
			results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("文件注册失败: %v", err)}
			continue
		}

		fileMu := h.getFileLock(fileID)
		fileMu.Lock()
		func() {
			defer fileMu.Unlock()

			latestVer, err := h.DB.GetLatestVersion(ctx, fileID)
			if err != nil {
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("查询最新版本失败: %v", err)}
				return
			}

			action := strings.ToLower(sf.Action)
			switch action {
			case "create", "update", "delete":
				if action == "create" && latestVer != nil {
					action = "update"
				}
				if action == "update" && latestVer == nil {
					action = "create"
				}
			default:
				if latestVer == nil {
					action = "create"
				} else {
					action = "update"
				}
			}

			if action == "delete" {
				if latestVer == nil {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: "文件无版本记录，无法删除"}
					return
				}
				if latestVer["action"].(string) == "delete" {
					results[i] = SnapshotResult{Path: sf.Path, Status: "unchanged"}
					return
				}

				baseVerID := latestVer["id"].(int64)
				versionID, err := h.DB.CreateVersion(ctx, fileID, "delete", nil, nil, &baseVerID, "delete", sourceID)
				if err != nil {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("写入删除版本失败: %v", err)}
					return
				}
				if err := h.DB.UpdateLatestVersion(ctx, fileID, versionID); err != nil {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("更新 latest_version 失败: %v", err)}
					return
				}
				results[i] = SnapshotResult{Path: sf.Path, Status: "captured", VersionID: &versionID}
				return
			}

			content := sf.Content
			if int64(len(content)) > h.Config.Storage.MaxFileSize {
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("文件大小 %d 超过限制 %d", len(content), h.Config.Storage.MaxFileSize)}
				return
			}

			contentBytes := []byte(content)
			contentHash := storage.ContentHash(contentBytes)

			if latestVer != nil {
				var prevHash string
				if latestVer["storageMode"].(string) == "blob" {
					if h := latestVer["blobHash"]; h != nil {
						prevHash = *h.(*string)
					}
				}

				if latestVer["storageMode"].(string) == "blob" && prevHash == contentHash {
					results[i] = SnapshotResult{Path: sf.Path, Status: "unchanged"}
					return
				}

				if latestVer["storageMode"].(string) == "delta" || latestVer["storageMode"].(string) == "blob" {
					prevContent, err := h.rebuildContent(ctx, latestVer)
					if err != nil {
						results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("重建上一版本内容失败: %v", err)}
						return
					}
					prevHashCheck := sha256.Sum256(prevContent)
					if hex.EncodeToString(prevHashCheck[:]) == contentHash {
						results[i] = SnapshotResult{Path: sf.Path, Status: "unchanged"}
						return
					}
				}
			}

			if latestVer == nil {
				hash, err := h.BlobStore.Store(contentBytes)
				if err != nil {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("存储 blob 失败: %v", err)}
					return
				}

				versionID, err := h.DB.CreateVersion(ctx, fileID, "blob", &hash, nil, nil, action, sourceID)
				if err != nil {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("写入版本记录失败: %v", err)}
					return
				}
				if err := h.DB.UpdateLatestVersion(ctx, fileID, versionID); err != nil {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("更新 latest_version 失败: %v", err)}
					return
				}
				results[i] = SnapshotResult{Path: sf.Path, Status: "captured", VersionID: &versionID}
				return
			}

			prevContent, err := h.rebuildContent(ctx, latestVer)
			if err != nil {
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("重建上一版本内容失败: %v", err)}
				return
			}

			diffs := dmp.DiffMain(string(prevContent), content, true)
			diffs = dmp.DiffCleanupSemantic(diffs)

			var meta *storage.DeltaMeta
			if req.SessionID != "" || req.Model != "" || sf.Message != "" {
				meta = &storage.DeltaMeta{
					SessionID: req.SessionID,
					Model:     req.Model,
					Message:   sf.Message,
				}
			}

			baseID := latestVer["id"].(int64)
			zeroOffset := int64(0)
			versionID, err := h.DB.CreateVersion(ctx, fileID, "delta", nil, &zeroOffset, &baseID, action, sourceID)
			if err != nil {
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("写入版本记录失败: %v", err)}
				return
			}

			threshold := h.Config.Compact.DeltaCompressThreshold
			offset, _, err := h.DeltaStore.Append(fileID, versionID, diffs, meta, threshold)
			if err != nil {
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("写入 delta 失败: %v", err)}
				return
			}

			if err := h.DB.UpdateVersionStorage(ctx, versionID, "delta", nil, &offset); err != nil {
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("更新 delta_offset 失败: %v", err)}
				return
			}

			if err := h.DB.UpdateLatestVersion(ctx, fileID, versionID); err != nil {
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("更新 latest_version 失败: %v", err)}
				return
			}

			results[i] = SnapshotResult{Path: sf.Path, Status: "captured", VersionID: &versionID}

			h.tryCompact(fileID)
		}()
	}

	return results
}

// ProcessLog 查询版本历史（非 HTTP 版本，给 MCP 用）。
func (h *Handler) ProcessLog(path, since, until, source, action string, limit, offset int) (map[string]any, error) {
	ctx := context.Background()
	project, err := h.DB.FindProjectByPath(ctx, path)
	if err != nil {
		return nil, fmt.Errorf("project not found: %w", err)
	}

	relPath := path
	rootPath := project["rootPath"].(string)
	if len(path) > len(rootPath) && path[:len(rootPath)] == rootPath {
		relPath = strings.TrimPrefix(path[len(rootPath):], "/")
	}

	file, err := h.DB.GetFileByPath(ctx, project["id"].(int64), relPath)
	if err != nil {
		return nil, fmt.Errorf("file not found: %w", err)
	}

	fileID := file["id"].(int64)

	var sourceID *int64
	if source != "" {
		sid, err := h.DB.GetSourceIDByName(ctx, source)
		if err != nil {
			return nil, fmt.Errorf("unknown source: %s", source)
		}
		sourceID = &sid
	}

	var actionFilter *string
	if action != "" {
		actionFilter = &action
	}

	var sinceP, untilP *string
	if since != "" {
		sinceP = &since
	}
	if until != "" {
		untilP = &until
	}

	versions, err := h.DB.ListVersions(ctx, fileID, sourceID, actionFilter, sinceP, untilP, limit, offset)
	if err != nil {
		return nil, fmt.Errorf("list versions: %w", err)
	}

	total, err := h.DB.CountVersions(ctx, fileID)
	if err != nil {
		return nil, fmt.Errorf("count versions: %w", err)
	}

	type versionEntry struct {
		VersionID int64  `json:"versionId"`
		Timestamp string `json:"timestamp"`
		Source    string `json:"source"`
		Action    string `json:"action"`
		SessionID string `json:"sessionId,omitempty"`
		Model     string `json:"model,omitempty"`
		Message   string `json:"message,omitempty"`
	}

	resultVersions := make([]versionEntry, 0, len(versions))
	for _, v := range versions {
		entry := versionEntry{
			VersionID: v["versionId"].(int64),
			Timestamp: v["timestamp"].(string),
			Source:    v["source"].(string),
			Action:    v["action"].(string),
		}
		if v["storageMode"].(string) == "delta" {
			meta, err := h.readDeltaMeta(ctx, fileID, v["versionId"].(int64))
			if err == nil && meta != nil {
				entry.SessionID = meta.SessionID
				entry.Model = meta.Model
				entry.Message = meta.Message
			}
		}
		resultVersions = append(resultVersions, entry)
	}

	return map[string]any{
		"file":          path,
		"project":       project["name"].(string),
		"totalVersions": total,
		"versions":      resultVersions,
	}, nil
}

// ProcessRestore 恢复文件内容（非 HTTP 版本，给 MCP 用）。
func (h *Handler) ProcessRestore(path string, version int64) (map[string]any, error) {
	ctx := context.Background()
	project, err := h.DB.FindProjectByPath(ctx, path)
	if err != nil {
		return nil, fmt.Errorf("project not found: %w", err)
	}

	relPath := path
	rootPath := project["rootPath"].(string)
	if len(path) > len(rootPath) && path[:len(rootPath)] == rootPath {
		relPath = strings.TrimPrefix(path[len(rootPath):], "/")
	}

	file, err := h.DB.GetFileByPath(ctx, project["id"].(int64), relPath)
	if err != nil {
		return nil, fmt.Errorf("file not found: %w", err)
	}

	fileID := file["id"].(int64)

	fileMu := h.getFileLock(fileID)
	fileMu.RLock()
	defer fileMu.RUnlock()

	ver, err := h.DB.GetVersion(ctx, version)
	if err != nil {
		return nil, fmt.Errorf("version not found: %w", err)
	}

	if ver["fileID"].(int64) != fileID {
		return nil, fmt.Errorf("version does not belong to this file")
	}

	if ver["action"].(string) == "delete" {
		return nil, fmt.Errorf("delete version has no content")
	}

	content, err := h.rebuildContent(ctx, ver)
	if err != nil {
		return nil, fmt.Errorf("rebuild content: %w", err)
	}

	return map[string]any{
		"path":      path,
		"version":   version,
		"timestamp": ver["changedAt"].(string),
		"content":   string(content),
	}, nil
}

// ProcessDiff 对比两个版本差异（非 HTTP 版本，给 MCP 用）。
func (h *Handler) ProcessDiff(path string, versionA, versionB int64) (map[string]any, error) {
	ctx := context.Background()
	project, err := h.DB.FindProjectByPath(ctx, path)
	if err != nil {
		return nil, fmt.Errorf("project not found: %w", err)
	}

	relPath := path
	rootPath := project["rootPath"].(string)
	if len(path) > len(rootPath) && path[:len(rootPath)] == rootPath {
		relPath = strings.TrimPrefix(path[len(rootPath):], "/")
	}

	file, err := h.DB.GetFileByPath(ctx, project["id"].(int64), relPath)
	if err != nil {
		return nil, fmt.Errorf("file not found: %w", err)
	}

	fileID := file["id"].(int64)

	fileMu := h.getFileLock(fileID)
	fileMu.RLock()
	defer fileMu.RUnlock()

	verA, err := h.DB.GetVersion(ctx, versionA)
	if err != nil {
		return nil, fmt.Errorf("version %d not found: %w", versionA, err)
	}
	verB, err := h.DB.GetVersion(ctx, versionB)
	if err != nil {
		return nil, fmt.Errorf("version %d not found: %w", versionB, err)
	}

	if verA["fileID"].(int64) != fileID {
		return nil, fmt.Errorf("version %d does not belong to this file", versionA)
	}
	if verB["fileID"].(int64) != fileID {
		return nil, fmt.Errorf("version %d does not belong to this file", versionB)
	}

	if verA["action"].(string) == "delete" {
		return nil, fmt.Errorf("version %d is deleted", versionA)
	}
	if verB["action"].(string) == "delete" {
		return nil, fmt.Errorf("version %d is deleted", versionB)
	}

	var diffs []diffmatchpatch.Diff
	isAdjacentDelta := false

	if verB["storageMode"].(string) == "delta" && verB["baseID"] != nil && *(verB["baseID"].(*int64)) == verA["id"].(int64) {
		offset := verB["deltaOffset"].(*int64)
		if offset != nil {
			_, readDiffs, _, err := h.DeltaStore.ReadEntry(fileID, *offset)
			if err == nil {
				diffs = readDiffs
				isAdjacentDelta = true
			}
		}
	}

	if !isAdjacentDelta {
		contentA, err := h.rebuildContent(ctx, verA)
		if err != nil {
			return nil, fmt.Errorf("rebuild version %d: %w", versionA, err)
		}
		contentB, err := h.rebuildContent(ctx, verB)
		if err != nil {
			return nil, fmt.Errorf("rebuild version %d: %w", versionB, err)
		}

		dmp := diffmatchpatch.New()
		diffs = dmp.DiffMain(string(contentA), string(contentB), true)
		diffs = dmp.DiffCleanupSemantic(diffs)
	}

	unified := renderUnifiedDiff(path, verA["changedAt"].(string), verB["changedAt"].(string), diffs)

	return map[string]any{
		"path": path,
		"from": versionA,
		"to":   versionB,
		"diff": unified,
	}, nil
}
