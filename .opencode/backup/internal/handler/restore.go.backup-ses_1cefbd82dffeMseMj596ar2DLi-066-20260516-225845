package handler

import (
	"fmt"
	"net/http"
	"strconv"
	"strings"
)

// HandleRestore 处理 GET /api/files/:path/restore/:version。
// 恢复指定版本的完整文件内容（不写盘，纯返回）。
func (h *Handler) HandleRestore(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodGet {
		writeError(w, http.StatusMethodNotAllowed, "METHOD_NOT_ALLOWED", "仅支持 GET")
		return
	}

	// 提取路径和版本号
	// URL 形如：/api/files/home/user/project/main.go/restore/42
	// 需要解析出 path 和 version
	path, versionID, err := parseRestorePath(r.URL.Path)
	if err != nil {
		writeError(w, http.StatusBadRequest, "INVALID_REQUEST", err.Error())
		return
	}

	if versionID <= 0 {
		writeError(w, http.StatusBadRequest, "INVALID_REQUEST", "无效的版本号")
		return
	}

	// 根据 path 匹配 project
	project, err := h.DB.FindProjectByPath(path)
	if err != nil {
		writeError(w, http.StatusNotFound, "PROJECT_NOT_FOUND", err.Error())
		return
	}

	// 计算相对路径
	relPath := path
	rootPath := project["rootPath"].(string)
	if len(path) > len(rootPath) && path[:len(rootPath)] == rootPath {
		relPath = strings.TrimPrefix(path[len(rootPath):], "/")
	}

	// 查文件
	file, err := h.DB.GetFileByPath(project["id"].(int64), relPath)
	if err != nil {
		writeError(w, http.StatusNotFound, "FILE_NOT_FOUND", err.Error())
		return
	}

	fileID := file["id"].(int64)

	// 加 per-file 共享锁（读操作）
	fileMu := h.getFileLock(fileID)
	fileMu.RLock()
	defer fileMu.RUnlock()

	// 查版本
	ver, err := h.DB.GetVersion(versionID)
	if err != nil {
		writeError(w, http.StatusNotFound, "VERSION_NOT_FOUND", err.Error())
		return
	}

	// 验证版本属于该文件
	if ver["fileID"].(int64) != fileID {
		writeError(w, http.StatusBadRequest, "INVALID_REQUEST", "版本不属于该文件")
		return
	}

	// delete 版本不可恢复
	if ver["action"].(string) == "delete" {
		writeError(w, http.StatusBadRequest, "INVALID_REQUEST", "delete 版本无内容可恢复")
		return
	}

	// 重建完整内容
	content, err := h.rebuildContent(ver)
	if err != nil {
		writeError(w, http.StatusInternalServerError, "CORRUPTED_DATA", fmt.Sprintf("数据恢复失败: %v", err))
		return
	}

	resp := map[string]any{
		"path":      path,
		"version":   versionID,
		"timestamp": ver["changedAt"].(string),
		"content":   string(content),
	}

	writeJSON(w, http.StatusOK, resp)
}

// parseRestorePath 解析 restore URL 路径。
// 输入: /api/files/some/path/restore/42
// 输出: some/path, 42, nil
func parseRestorePath(urlPath string) (string, int64, error) {
	// 去掉 /api/files/ 前缀
	const prefix = "/api/files/"
	if !strings.HasPrefix(urlPath, prefix) {
		return "", 0, fmt.Errorf("无效的路径格式")
	}

	rest := urlPath[len(prefix):]

	// 找到 /restore/ 分隔符
	const restoreSep = "/restore/"
	idx := strings.LastIndex(rest, restoreSep)
	if idx < 0 {
		return "", 0, fmt.Errorf("缺少 /restore/:version 部分")
	}

	path := rest[:idx]
	versionStr := rest[idx+len(restoreSep):]

	versionID, err := strconv.ParseInt(versionStr, 10, 64)
	if err != nil {
		return "", 0, fmt.Errorf("无效的版本号: %s", versionStr)
	}

	return path, versionID, nil
}

