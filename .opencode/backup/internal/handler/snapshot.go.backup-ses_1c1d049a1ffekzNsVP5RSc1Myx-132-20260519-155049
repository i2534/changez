package handler

import (
	"context"
	"crypto/sha256"
	"encoding/hex"
	"encoding/json"
	"fmt"
	"net/http"
	"strconv"
	"strings"
	"time"

	"github.com/sergi/go-diff/diffmatchpatch"

	"github.com/changez/changez/internal/storage"
)

type SnapshotRequest struct {
	Source    string         `json:"source"`
	SessionID string         `json:"sessionId,omitempty"`
	Model     string         `json:"model,omitempty"`
	Files     []SnapshotFile `json:"files"`
}

type SnapshotFile struct {
	Path    string `json:"path"`
	Content string `json:"content,omitempty"`
	Action  string `json:"action,omitempty"`
	Message string `json:"message,omitempty"`
}

type SnapshotResult struct {
	Path      string `json:"path"`
	Status    string `json:"status"`
	VersionID *int64 `json:"versionId,omitempty"`
	Reason    string `json:"reason,omitempty"`
}

type SnapshotResponse struct {
	Results []SnapshotResult `json:"results"`
	Summary SnapshotSummary  `json:"summary"`
}

type SnapshotSummary struct {
	Captured  int `json:"captured"`
	Unchanged int `json:"unchanged"`
	Errors    int `json:"errors"`
}

func (h *Handler) HandleSnapshot(w http.ResponseWriter, r *http.Request) {
	if r.Method != http.MethodPost {
		writeError(w, http.StatusMethodNotAllowed, "METHOD_NOT_ALLOWED", "仅支持 POST")
		return
	}

	var req SnapshotRequest
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		h.Logger.Warn("snapshot parse error", "error", err)
		writeError(w, http.StatusBadRequest, "INVALID_REQUEST", fmt.Sprintf("请求体解析失败: %v", err))
		return
	}

	sourceID, ok := h.SourceIDs[req.Source]
	if !ok {
		h.Logger.Warn("snapshot invalid source", "source", req.Source)
		writeError(w, http.StatusBadRequest, "INVALID_REQUEST", fmt.Sprintf("不支持的 source: %s", req.Source))
		return
	}

	if len(req.Files) == 0 {
		h.Logger.Warn("snapshot empty files")
		writeError(w, http.StatusBadRequest, "INVALID_REQUEST", "files 不能为空")
		return
	}

	h.Logger.Info("snapshot request",
		"file_count", len(req.Files),
		"source", req.Source,
		"session_id", req.SessionID,
		"model", req.Model,
	)

	ctx := r.Context()
	results := make([]SnapshotResult, len(req.Files))
	summary := SnapshotSummary{}

	dmp := diffmatchpatch.New()

	for i, sf := range req.Files {
		// 校验 path
		if sf.Path == "" {
			results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: "path 不能为空"}
			summary.Errors++
			continue
		}

		// 1. 根据 path 匹配项目（最长前缀匹配）
		project, err := h.DB.FindProjectByPath(ctx, sf.Path)
		if err != nil {
			h.Logger.Warn("project not found for path", "path", sf.Path, "error", err)
			results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: err.Error()}
			summary.Errors++
			continue
		}

		// 计算相对路径
		relPath := sf.Path
		rootPath := project["rootPath"].(string)
		if len(sf.Path) > len(rootPath) && sf.Path[:len(rootPath)] == rootPath {
			relPath = strings.TrimPrefix(sf.Path[len(rootPath):], "/")
		}

		// 2. upsert 文件记录
		fileID, err := h.DB.UpsertFile(ctx, project["id"].(int64), relPath)
		if err != nil {
			results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("文件注册失败: %v", err)}
			summary.Errors++
			continue
		}

		// 3. 加 per-file 排他锁
		fileMu := h.getFileLock(fileID)
		fileMu.Lock()

		func() {
			defer fileMu.Unlock()

			// 4. 查最新版本
			latestVer, err := h.DB.GetLatestVersion(ctx, fileID)
			if err != nil {
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("查询最新版本失败: %v", err)}
				summary.Errors++
				return
			}

			// 5. action 双重判断
			action := strings.ToLower(sf.Action)
			switch action {
			case "create", "update", "delete":
				if action == "create" && latestVer != nil {
					action = "update"
				}
				if action == "update" && latestVer == nil {
					action = "create"
				}
			case "":
				if latestVer == nil {
					action = "create"
				} else {
					action = "update"
				}
			default:
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("不支持的 action: %s", sf.Action)}
				summary.Errors++
				return
			}

			// delete action 特殊处理
			if action == "delete" {
				if latestVer == nil {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: "文件无版本记录，无法删除"}
					summary.Errors++
					return
				}

				if latestVer["action"].(string) == "delete" {
					h.Logger.Debug("unchanged (already deleted)", "path", sf.Path)
					results[i] = SnapshotResult{Path: sf.Path, Status: "unchanged"}
					summary.Unchanged++
					return
				}

				baseVerID := latestVer["id"].(int64)
				versionID, err := h.DB.CreateVersion(
					ctx,
					fileID,
					"delete",
					nil,
					nil,
					&baseVerID,
					"delete",
					sourceID,
				)
				if err != nil {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("写入删除版本失败: %v", err)}
					summary.Errors++
					return
				}

				if err := h.DB.UpdateLatestVersion(ctx, fileID, versionID); err != nil {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("更新 latest_version 失败: %v", err)}
					summary.Errors++
					return
				}

				results[i] = SnapshotResult{Path: sf.Path, Status: "captured", VersionID: &versionID}
				summary.Captured++
				h.Logger.Debug("captured (delete)", "path", sf.Path, "version_id", versionID)
				return
			}

			// create/update：校验 content
			content := sf.Content
			if int64(len(content)) > h.Config.Storage.MaxFileSize {
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("文件大小 %d 超过限制 %d", len(content), h.Config.Storage.MaxFileSize)}
				summary.Errors++
				return
			}

			contentBytes := []byte(content)
			contentHash := storage.ContentHash(contentBytes)

			var prevContent []byte
			if latestVer != nil {
				prevContent, err = h.rebuildContent(ctx, latestVer)
				if err != nil {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("重建上一版本内容失败: %v", err)}
					summary.Errors++
					return
				}
			}

			// 6. 幂等性检查：与最新版本 hash 对比
			if latestVer != nil {
				if latestVer["storageMode"].(string) == "blob" {
					if bh := latestVer["blobHash"]; bh != nil {
						prevHash := *(bh.(*string))
						if prevHash == contentHash {
							h.Logger.Debug("unchanged (blob hash match)", "path", sf.Path, "hash", contentHash)
							results[i] = SnapshotResult{Path: sf.Path, Status: "unchanged"}
							summary.Unchanged++
							return
						}
					}
				}

				prevHashCheck := sha256.Sum256(prevContent)
				if hex.EncodeToString(prevHashCheck[:]) == contentHash {
					h.Logger.Debug("unchanged (content match)", "path", sf.Path, "hash", contentHash)
					results[i] = SnapshotResult{Path: sf.Path, Status: "unchanged"}
					summary.Unchanged++
					return
				}
			}

			// 7. 首次创建：存完整 blob
			if latestVer == nil {
				hash, err := h.BlobStore.Store(contentBytes)
				if err != nil {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("存储 blob 失败: %v", err)}
					summary.Errors++
					return
				}

				versionID, err := h.DB.CreateVersion(
					ctx,
					fileID,
					"blob",
					&hash,
					nil,
					nil,
					action,
					sourceID,
				)
				if err != nil {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("写入版本记录失败: %v", err)}
					summary.Errors++
					return
				}

				if err := h.DB.UpdateLatestVersion(ctx, fileID, versionID); err != nil {
					results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("更新 latest_version 失败: %v", err)}
					summary.Errors++
					return
				}

				results[i] = SnapshotResult{Path: sf.Path, Status: "captured", VersionID: &versionID}
				summary.Captured++
				h.Logger.Debug("captured (blob)", "path", sf.Path, "version_id", versionID, "storage", "blob")
				return
			}

			// 8. 有历史：生成 delta
			diffs := dmp.DiffMain(string(prevContent), content, true)
			diffs = dmp.DiffCleanupSemantic(diffs)

			var meta *storage.DeltaMeta
			if req.SessionID != "" || req.Model != "" || sf.Message != "" {
				meta = &storage.DeltaMeta{
					SessionID: req.SessionID,
					Model:     req.Model,
					Message:   sf.Message,
				}
			}

			baseID := latestVer["id"].(int64)

			// 事务：CreateVersion → Append → UpdateVersionStorage → UpdateLatestVersion
			tx, txErr := h.DB.BeginTx(ctx)
			if txErr != nil {
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("开启事务失败: %v", txErr)}
				summary.Errors++
				return
			}

			versionID, txErr := tx.CreateVersion(
				ctx,
				fileID,
				"delta",
				nil,
				nil,
				&baseID,
				action,
				sourceID,
			)
			if txErr != nil {
				tx.Rollback()
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("写入版本记录失败: %v", txErr)}
				summary.Errors++
				return
			}

			threshold := h.Config.Compact.DeltaCompressThreshold
			offset, _, txErr := h.DeltaStore.Append(
				fileID,
				versionID,
				diffs,
				meta,
				threshold,
			)
			if txErr != nil {
				tx.Rollback()
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("写入 delta 失败: %v", txErr)}
				summary.Errors++
				return
			}

			if txErr := tx.UpdateVersionStorage(ctx, versionID, "delta", nil, &offset); txErr != nil {
				tx.Rollback()
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("更新 delta_offset 失败: %v", txErr)}
				summary.Errors++
				return
			}

			if txErr := tx.UpdateLatestVersion(ctx, fileID, versionID); txErr != nil {
				tx.Rollback()
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("更新 latest_version 失败: %v", txErr)}
				summary.Errors++
				return
			}

			if txErr := tx.Commit(); txErr != nil {
				results[i] = SnapshotResult{Path: sf.Path, Status: "error", Reason: fmt.Sprintf("提交事务失败: %v", txErr)}
				summary.Errors++
				return
			}

			results[i] = SnapshotResult{Path: sf.Path, Status: "captured", VersionID: &versionID}
			summary.Captured++
			h.Logger.Debug("captured (delta)", "path", sf.Path, "version_id", versionID)

			h.tryCompact(fileID)
		}()
	}

	// 按 projectRoot 聚合 captured 文件，写入 latestSnapshots 缓存
	h.updateLatestSnapshotCache(results)

	resp := SnapshotResponse{
		Results: results,
		Summary: summary,
	}
	h.Logger.Info("snapshot complete",
		"captured", summary.Captured,
		"unchanged", summary.Unchanged,
		"errors", summary.Errors,
	)
	writeJSON(w, http.StatusOK, resp)
}

// rebuildContent 根据版本记录重建完整文件内容。
func (h *Handler) rebuildContent(ctx context.Context, ver map[string]any) ([]byte, error) {
	storageMode := ver["storageMode"].(string)

	switch storageMode {
	case "blob":
		hash := ver["blobHash"].(*string)
		if hash == nil {
			return nil, fmt.Errorf("blob 模式但 hash 为空")
		}
		return h.BlobStore.Read(*hash)

	case "delta":
		return h.rebuildFromDeltaChain(ctx, ver)

	case "delete":
		return nil, fmt.Errorf("delete 版本无内容可恢复")

	default:
		return nil, fmt.Errorf("不支持的存储模式: %s", storageMode)
	}
}

// rebuildFromDeltaChain 从指定版本回溯到最近的 blob checkpoint，重建完整内容。
func (h *Handler) rebuildFromDeltaChain(ctx context.Context, ver map[string]any) ([]byte, error) {
	dmp := diffmatchpatch.New()

	type deltaStep struct {
		diffs []diffmatchpatch.Diff
	}

	var steps []deltaStep
	currentVer := ver

	for {
		switch currentVer["storageMode"].(string) {
		case "blob":
			hash := currentVer["blobHash"].(*string)
			if hash == nil {
				return nil, fmt.Errorf("blob checkpoint 但 hash 为空")
			}
			content, err := h.BlobStore.Read(*hash)
			if err != nil {
				return nil, fmt.Errorf("读取 blob checkpoint 失败: %w", err)
			}

			for i := len(steps) - 1; i >= 0; i-- {
				content = applyPatch(dmp, content, steps[i].diffs)
			}
			return content, nil

		case "delta":
			offset := currentVer["deltaOffset"].(*int64)
			if offset == nil {
				return nil, fmt.Errorf("delta 模式但 offset 为空")
			}
			fileID := currentVer["fileID"].(int64)

			_, diffs, _, err := h.DeltaStore.ReadEntry(fileID, *offset)
			if err != nil {
				return nil, fmt.Errorf("读取 delta entry 失败: %w", err)
			}
			steps = append(steps, deltaStep{diffs: diffs})

			baseID := currentVer["baseID"]
			if baseID == nil {
				return nil, fmt.Errorf("delta 模式但 base_id 为空")
			}
			bid := *baseID.(*int64)
			baseVer, err := h.DB.GetVersion(ctx, bid)
			if err != nil {
				return nil, fmt.Errorf("查询 base version %d 失败: %w", bid, err)
			}
			currentVer = baseVer

		default:
			return nil, fmt.Errorf("不支持的存储模式: %s", currentVer["storageMode"].(string))
		}
	}
}

// applyPatch 对内容应用 go-diff 的 []Diff（PatchApply）。
func applyPatch(dmp *diffmatchpatch.DiffMatchPatch, text []byte, diffs []diffmatchpatch.Diff) []byte {
	patches := dmp.PatchMake(string(text), diffs)
	result, _ := dmp.PatchApply(patches, string(text))
	return []byte(result)
}

// HandleListFiles 处理 GET /api/files，列出所有追踪的文件。
func (h *Handler) HandleListFiles(w http.ResponseWriter, r *http.Request) {
	ctx := r.Context()
	q := r.URL.Query()

	// 解析查询参数
	projectFilter := q.Get("project")
	limit := 100
	offset := 0

	if l := q.Get("limit"); l != "" {
		if n, err := strconv.Atoi(l); err == nil && n > 0 && n <= 1000 {
			limit = n
		}
	}
	if o := q.Get("offset"); o != "" {
		if n, err := strconv.Atoi(o); err == nil && n >= 0 {
			offset = n
		}
	}

	// 构建查询
	query := `
		SELECT p.name as project_name, f.path, f.latest_version_id, f.created_at
		FROM files f
		JOIN projects p ON f.project_id = p.id
		WHERE p.is_deleted = 0
	`
	args := []any{}

	if projectFilter != "" {
		query += " AND p.name = ?"
		args = append(args, projectFilter)
	}

	query += " ORDER BY p.name, f.path LIMIT ? OFFSET ?"
	args = append(args, limit, offset)

	rows, err := h.DB.Query(ctx, query, args...)
	if err != nil {
		writeError(w, http.StatusInternalServerError, "INTERNAL_ERROR", fmt.Sprintf("查询文件列表失败: %v", err))
		return
	}
	defer rows.Close()

	type fileEntry struct {
		Project         string `json:"project"`
		Path            string `json:"path"`
		LatestVersionID *int64 `json:"latestVersionId"`
		CreatedAt       string `json:"createdAt"`
	}

	var files []fileEntry
	for rows.Next() {
		var projectName, filePath, createdAt string
		var latestVersionID *int64
		if err := rows.Scan(&projectName, &filePath, &latestVersionID, &createdAt); err != nil {
			writeError(w, http.StatusInternalServerError, "INTERNAL_ERROR", fmt.Sprintf("扫描文件行失败: %v", err))
			return
		}
		files = append(files, fileEntry{
			Project:         projectName,
			Path:            filePath,
			LatestVersionID: latestVersionID,
			CreatedAt:       createdAt,
		})
	}

	if files == nil {
		files = []fileEntry{}
	}

	writeJSON(w, http.StatusOK, map[string]any{"files": files})
}

// HandleStats 处理 GET /api/stats。
func (h *Handler) HandleStats(w http.ResponseWriter, r *http.Request) {
	h.Logger.Debug("stats request")
	stats, err := h.DB.GetStats(r.Context())
	if err != nil {
		writeError(w, http.StatusInternalServerError, "INTERNAL_ERROR", fmt.Sprintf("查询统计失败: %v", err))
		return
	}
	writeJSON(w, http.StatusOK, stats)
}
