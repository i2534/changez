package mcp

import (
	"net/http"

	"github.com/mark3labs/mcp-go/server"

	"github.com/changez/changez/internal/config"
	"github.com/changez/changez/internal/db"
	"github.com/changez/changez/internal/handler"
	"github.com/changez/changez/internal/storage"
)

func NewMCPHandler(
	database *db.DB,
	blobStore *storage.BlobStore,
	deltaStore *storage.DeltaStore,
	cfg *config.Config,
	sourceIDs map[string]int64,
) http.Handler {
	s := server.NewMCPServer("changez", "1.0.0",
		server.WithToolCapabilities(true),
		server.WithLogging(),
	)

	h := handler.NewHandler(database, blobStore, deltaStore, cfg, sourceIDs)

	tool, handlerFunc := NewSnapshotTool(h)
	s.AddTool(tool, handlerFunc)

	tool, handlerFunc = NewLogTool(h)
	s.AddTool(tool, handlerFunc)

	tool, handlerFunc = NewRestoreTool(h)
	s.AddTool(tool, handlerFunc)

	tool, handlerFunc = NewDiffTool(h)
	s.AddTool(tool, handlerFunc)

	return server.NewStreamableHTTPServer(s)
}
