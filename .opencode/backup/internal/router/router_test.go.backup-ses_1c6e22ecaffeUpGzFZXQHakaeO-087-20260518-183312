func setupRouter(t *testing.T) http.Handler {
	t.Helper()
	dir := t.TempDir()
	database, err := db.Open(dir)
	require.NoError(t, err)

	bs := storage.NewBlobStore(dir)
	require.NoError(t, bs.EnsureDir())

	ds := storage.NewDeltaStore(dir)
	require.NoError(t, ds.EnsureDir())

	cfg := config.Defaults()
	sourceIDs, err := database.LoadSourceNameToID()
	require.NoError(t, err)

	fileMuMap := &sync.Map{}
	logger := handler.NewLogger(&cfg)
	compactor := compact.New(database, bs, ds, &cfg.Compact, logger, fileMuMap)

	return New(database, bs, ds, &cfg, sourceIDs, "", fileMuMap, compactor)
}

func setupRouterWithToken(t *testing.T, token string) http.Handler {
	t.Helper()
	dir := t.TempDir()
	database, err := db.Open(dir)
	require.NoError(t, err)

	bs := storage.NewBlobStore(dir)
	require.NoError(t, bs.EnsureDir())

	ds := storage.NewDeltaStore(dir)
	require.NoError(t, ds.EnsureDir())

	cfg := config.Defaults()
	cfg.Token = token
	sourceIDs, err := database.LoadSourceNameToID()
	require.NoError(t, err)

	fileMuMap := &sync.Map{}
	logger := handler.NewLogger(&cfg)
	compactor := compact.New(database, bs, ds, &cfg.Compact, logger, fileMuMap)

	return New(database, bs, ds, &cfg, sourceIDs, token, fileMuMap, compactor)
}

func createProjectViaRouter(t *testing.T, router http.Handler) {
	t.Helper()
	body := `{"rootPath":"/home/user/proj","name":"test"}`
	req := httptest.NewRequest(http.MethodPost, "/api/projects", strings.NewReader(body))
	req.Header.Set("Content-Type", "application/json")
	w := httptest.NewRecorder()
	router.ServeHTTP(w, req)
	require.Equal(t, http.StatusCreated, w.Code)
}

func setupHandler(t *testing.T) (*handler.Handler, *db.DB, *storage.BlobStore, *storage.DeltaStore) {
	t.Helper()
	dir := t.TempDir()
	database, err := db.Open(dir)
	require.NoError(t, err)

	bs := storage.NewBlobStore(dir)
	require.NoError(t, bs.EnsureDir())

	ds := storage.NewDeltaStore(dir)
	require.NoError(t, ds.EnsureDir())

	cfg := config.Defaults()
	sourceIDs, err := database.LoadSourceNameToID()
	require.NoError(t, err)

	fileMuMap := &sync.Map{}
	h := handler.NewHandler(database, bs, ds, &cfg, sourceIDs, fileMuMap)

	return h, database, bs, ds
}

