func TestBlobStore_Read_BadMagic(t *testing.T) {
	tmpDir := t.TempDir()
	bs := NewBlobStore(tmpDir)
	require.NoError(t, bs.EnsureDir())

	hash := strings.Repeat("b", 64)
	badMagicFile := filepath.Join(tmpDir, "blobs", hash)
	header := make([]byte, BlobHeaderSize)
	binary.BigEndian.PutUint32(header[0:4], 0xDEADBEEF) // 错误魔数
	binary.BigEndian.PutUint16(header[4:6], CompressZstd)
	err := os.WriteFile(badMagicFile, header, 0o644)
	require.NoError(t, err)

	_, err = bs.Read(hash)
	assert.Error(t, err)
	assert.Contains(t, err.Error(), "invalid magic")
}

