func TestBlobStore_CompressNone(t *testing.T) {
	tmpDir := t.TempDir()
	bs := NewBlobStore(tmpDir)
	require.NoError(t, bs.EnsureDir())

	content := []byte("test content")
	hash, err := bs.Store(content)
	require.NoError(t, err)

	// 直接读取文件验证压缩方法
	data, err := os.ReadFile(filepath.Join(tmpDir, "blobs", hash))
	require.NoError(t, err)
	require.GreaterOrEqual(t, len(data), BlobHeaderSize)

	compressMethod := binary.BigEndian.Uint16(data[4:6])
	assert.Equal(t, CompressZstd, compressMethod, "BlobStore should use zstd compression")
}

func TestDeltaStore_VerifyCompressedData(t *testing.T) {
	tmpDir := t.TempDir()
	ds := NewDeltaStore(tmpDir)
	require.NoError(t, ds.EnsureDir())

	// 创建大数据以触发压缩
	largeText := ""
	for i := 0; i < 500; i++ {
		largeText += "x"
	}
	diffs := []diffmatchpatch.Diff{
		{Type: diffmatchpatch.DiffEqual, Text: largeText},
	}

	offset, _, err := ds.Append(1, 1, diffs, nil, 100)
	require.NoError(t, err)

	// 直接读取文件验证压缩方法
	data, err := os.ReadFile(filepath.Join(tmpDir, "deltas", "1.delta"))
	require.NoError(t, err)

	// 跳到指定 offset 验证
	remaining := data[offset:]
	compressMethod := binary.BigEndian.Uint16(remaining[8:10])
	assert.Equal(t, CompressZstd, compressMethod, "should use zstd compression for large data")

	// 验证可以正确解压读取
	readVersionID, readDiffs, _, err := ds.ReadEntry(1, offset)
	require.NoError(t, err)
	assert.Equal(t, int64(1), readVersionID)
	assert.Equal(t, diffs, readDiffs)
}

// ==================== Helper for string repetition ====================

// 简单的字符串重复辅助方法
type repeatString string

func (s repeatString) repeat(n int) string {
	result := ""
	for i := 0; i < n; i++ {
		result += string(s)
	}
	return result
}

// ==================== Direct Zstd Compression Test ====================

func TestZstdRoundTrip(t *testing.T) {
	content := []byte("test content for zstd compression")

	// 压缩
	var compressed bytes.Buffer
	w, err := zstd.NewWriter(&compressed)
	require.NoError(t, err)
	_, err = w.Write(content)
	require.NoError(t, err)
	require.NoError(t, w.Close())

	// 解压
	r, err := zstd.NewReader(bytes.NewReader(compressed.Bytes()))
	require.NoError(t, err)
	defer r.Close()

	var decompressed bytes.Buffer
	_, err = decompressed.ReadFrom(r)
	require.NoError(t, err)

	assert.Equal(t, content, decompressed.Bytes())
}

