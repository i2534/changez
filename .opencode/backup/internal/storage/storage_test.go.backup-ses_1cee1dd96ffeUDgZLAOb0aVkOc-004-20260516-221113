func TestDeltaStore_Append_ValidHeader(t *testing.T) {
	tmpDir := t.TempDir()
	ds := NewDeltaStore(tmpDir)
	require.NoError(t, ds.EnsureDir())

	diffs := []diffmatchpatch.Diff{
		{Type: diffmatchpatch.DiffEqual, Text: "hello\n"},
		{Type: diffmatchpatch.DiffInsert, Text: "world\n"},
	}

	offset, _, err := ds.Append(1, 100, diffs, nil, 1024)
	require.NoError(t, err)
	assert.Equal(t, int64(0), offset)

	// 读取文件验证 header
	data, err := os.ReadFile(filepath.Join(tmpDir, "deltas", "1.delta"))
	require.NoError(t, err)
	require.GreaterOrEqual(t, len(data), DeltaHeaderSize)

	magic := binary.BigEndian.Uint32(data[0:4])
	assert.Equal(t, DeltaMagic, magic, "magic should be 0x43440001")

	versionID := binary.BigEndian.Uint32(data[4:8])
	assert.Equal(t, uint32(100), versionID)
}

func TestDeltaStore_Append_OffsetIncrement(t *testing.T) {
	tmpDir := t.TempDir()
	ds := NewDeltaStore(tmpDir)
