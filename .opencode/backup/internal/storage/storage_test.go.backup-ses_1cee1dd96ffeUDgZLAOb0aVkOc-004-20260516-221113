func TestDeltaStore_MultipleAppends(t *testing.T) {
	tmpDir := t.TempDir()
	ds := NewDeltaStore(tmpDir)
	require.NoError(t, ds.EnsureDir())

	// 写入多个条目
	entries := []struct {
		versionID int64
		diffs     []diffmatchpatch.Diff
	}{
		{1, []diffmatchpatch.Diff{{Type: diffmatchpatch.DiffEqual, Text: "first\n"}}},
		{2, []diffmatchpatch.Diff{{Type: diffmatchpatch.DiffInsert, Text: "second\n"}}},
		{3, []diffmatchpatch.Diff{{Type: diffmatchpatch.DiffDelete, Text: "third\n"}}},
	}

	var offsets []int64
	for _, entry := range entries {
		offset, _, err := ds.Append(1, entry.versionID, entry.diffs, nil, 1024)
		require.NoError(t, err)
		offsets = append(offsets, offset)
	}

	// 验证每个条目都能正确读取
	for i, entry := range entries {
		readVersionID, readDiffs, _, err := ds.ReadEntry(1, offsets[i])
		require.NoError(t, err)
		assert.Equal(t, entry.versionID, readVersionID)
		assert.Equal(t, entry.diffs, readDiffs)
	}
}

